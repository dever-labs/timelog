# .env.example — FOR DEVELOPMENT ONLY
#
# Regular users: run `timelog init` — config is saved automatically to ~/.timelog/config.env
# Developers: copy this file to .env in the repo root to override settings locally
#
GITHUB_CLIENT_ID=Ov23li...
COPILOT_MODEL=gpt-4o
SAP_URL=https://your-sap-fiori-url.com
SAP_USERNAME=your_username
# SAP_PASSWORD optional — tool will prompt if not set

